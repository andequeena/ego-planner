# RViz 配置文件说明：
# - 这是 YAML 格式，`#` 开头的内容是注释，不会影响 RViz 读取。
# - 如果之后在 RViz 里点击 Save Config，RViz 可能会重新生成文件并删除这些注释。
# - 主要关注 `Visualization Manager -> Displays`，那里决定地图、轨迹、机器人等内容如何显示。
# Panels：RViz 左右侧停靠面板的布局配置，只影响界面面板，不影响话题显示内容。
Panels:
  - Class: rviz/Displays
    Help Height: 0
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Planning1
        - /Mapping1
        - /Mapping1/simulation_map1/Autocompute Value Bounds1
      Splitter Ratio: 0.5
    Tree Height: 170
  - Class: rviz/Selection
    Name: Selection
  - Class: rviz/Tool Properties
    Expanded:
      - /2D Pose Estimate1
      - /2D Nav Goal1
      - /Publish Point1
    Name: Tool Properties
    Splitter Ratio: 0.588679016
  - Class: rviz/Views
    Expanded:
      - /Current View1
      - /ThirdPersonFollower1
    Name: Views
    Splitter Ratio: 0.5
  - Class: rviz/Time
    Experimental: false
    Name: Time
    SyncMode: 0
    SyncSource: simulation_map

# Toolbars：RViz 顶部工具栏按钮的显示样式。
Toolbars:
  toolButtonStyle: 2

# Visualization Manager：RViz 的核心显示配置。
# 包含所有 Display、全局坐标系、工具、视角等。
Visualization Manager:
  Class: ""

  # Displays：左侧 Displays 面板中的所有显示对象。
  # 每个 `Class` 表示一种 RViz 显示插件，例如 Axes/Grid/Marker/PointCloud2/Path。
  Displays:

    # Axes：在 Fixed Frame 原点显示 xyz 坐标轴，方便判断 world 坐标系方向。
    - Class: rviz/Axes
      Enabled: true
      Length: 1
      Name: Axes
      Radius: 0.100000001
      Reference Frame: <Fixed Frame>
      Value: true

    # Grid：XY 平面网格，只是空间参考线，不来自 ROS topic。
    # Plane Cell Count 控制网格范围，Cell Size 控制每格大小。
    - Alpha: 0.5
      Cell Size: 1
      Class: rviz/Grid
      Color: 160; 160; 164
      Enabled: true
      Line Style:
        Line Width: 0.0299999993
        Value: Lines
      Name: Grid
      Normal Cell Count: 0
      Offset:
        X: 0
        Y: 0
        Z: 0
      Plane: XY
      Plane Cell Count: 40
      Reference Frame: <Fixed Frame>
      Value: true

    # Planning：规划相关显示分组，主要显示目标点、全局路径、优化轨迹、A* 路径、无人机历史轨迹。
    - Class: rviz/Group
      Displays:

        # goal_point：EGO planner 发布的目标点 Marker。
        # 你当前选中的 /goal_point 就在这里，对应 topic `/ego_planner_node/goal_point`。
        - Class: rviz/Marker
          Enabled: true
          Marker Topic: /ego_planner_node/goal_point
          Name: goal_point
          Namespaces:
            "": true
          Queue Size: 100
          Value: true

        # global_path：全局路径 Marker，当前 Enabled=false，所以默认不显示。
        # 需要调试全局路径时可以在 RViz Displays 面板中勾选。
        - Class: rviz/Marker
          Enabled: false
          Marker Topic: /ego_planner_node/global_list
          Name: global_path
          Namespaces:
            {}
          Queue Size: 100
          Value: false

        # optimal_traj：优化后的局部轨迹/最终轨迹 Marker，默认显示。
        # 通常用于观察 bspline 优化后的轨迹是否平滑、是否绕开障碍。
        - Class: rviz/Marker
          Enabled: true
          Marker Topic: /ego_planner_node/optimal_list
          Name: optimal_traj
          Namespaces:
            "": true
          Queue Size: 100
          Value: true

        # AStar：A* 搜索得到的离散绕障路径，默认关闭。
        # 调试避障搜索或 rebound 约束生成时可以打开。
        - Class: rviz/Marker
          Enabled: false
          Marker Topic: /ego_planner_node/a_star_list
          Name: AStar
          Namespaces:
            {}
          Queue Size: 100
          Value: false

        # InitTraj：优化前的初始轨迹，默认关闭。
        # 与 optimal_traj 对比可以看出优化器对轨迹做了哪些调整。
        - Class: rviz/Marker
          Enabled: false
          Marker Topic: /ego_planner_node/init_list
          Name: InitTraj
          Namespaces:
            {}
          Queue Size: 100
          Value: false

        # drone_path：无人机里程计轨迹 Path，来自 `/odom_visualization/path`。
        # 这是实际/仿真飞行历史路径，不是规划器当前输出的单条轨迹。
        - Alpha: 1
          Buffer Length: 1
          Class: rviz/Path
          Color: 25; 255; 0
          Enabled: true
          Head Diameter: 0.300000012
          Head Length: 0.200000003
          Length: 0.300000012
          Line Style: Lines
          Line Width: 0.0299999993
          Name: drone_path
          Offset:
            X: 0
            Y: 0
            Z: 0
          Pose Color: 255; 85; 255
          Pose Style: Axes
          Radius: 0.0299999993
          Shaft Diameter: 0.100000001
          Shaft Length: 0.100000001
          Topic: /odom_visualization/path
          Unreliable: false
          Value: true
      Enabled: true
      Name: Planning

    # Mapping：地图相关显示分组，显示全局点云、膨胀占据栅格、原始占据栅格。
    - Class: rviz/Group
      Displays:

        # simulation_map：地图生成器发布的全局点云，通常表示仿真环境障碍物。
        # Alpha=0.2 表示半透明；Style=Boxes 表示用小方块显示点云。
        - Alpha: 0.200000003
          Autocompute Intensity Bounds: true
          Autocompute Value Bounds:
            Max Value: 2
            Min Value: -1
            Value: false
          Axis: Z
          Channel Name: intensity
          Class: rviz/PointCloud2
          Color: 85; 170; 255
          Color Transformer: FlatColor
          Decay Time: 0
          Enabled: true
          Invert Rainbow: false
          Max Color: 255; 255; 255
          Max Intensity: 4096
          Min Color: 0; 0; 0
          Min Intensity: 0
          Name: simulation_map
          Position Transformer: XYZ
          Queue Size: 10
          Selectable: true
          Size (Pixels): 3
          Size (m): 0.100000001
          Style: Boxes
          Topic: /map_generator/global_cloud
          Unreliable: false
          Use Fixed Frame: true
          Use rainbow: true
          Value: true

        # map inflate：膨胀后的占据地图，规划器实际避障通常会参考这类膨胀障碍。
        # Topic `/grid_map/occupancy_inflate` 显示的是考虑安全距离后的障碍区域。
        - Alpha: 1
          Autocompute Intensity Bounds: true
          Autocompute Value Bounds:
            Max Value: 2.33999991
            Min Value: 0.0399999991
            Value: true
          Axis: Z
          Channel Name: intensity
          Class: rviz/PointCloud2
          Color: 255; 255; 255
          Color Transformer: AxisColor
          Decay Time: 0
          Enabled: true
          Invert Rainbow: false
          Max Color: 255; 255; 255
          Max Intensity: 4096
          Min Color: 0; 0; 0
          Min Intensity: 0
          Name: map inflate
          Position Transformer: XYZ
          Queue Size: 10
          Selectable: true
          Size (Pixels): 3
          Size (m): 0.100000001
          Style: Flat Squares
          Topic: /grid_map/occupancy_inflate
          Unreliable: false
          Use Fixed Frame: true
          Use rainbow: true
          Value: true

        # real_map：原始占据地图，当前 Enabled=false。
        # 和 map inflate 对比可以看出障碍膨胀后的安全裕度。
        - Alpha: 1
          Autocompute Intensity Bounds: true
          Autocompute Value Bounds:
            Max Value: 2.75925088
            Min Value: -0.922850013
            Value: false
          Axis: Z
          Channel Name: intensity
          Class: rviz/PointCloud2
          Color: 187; 187; 187
          Color Transformer: AxisColor
          Decay Time: 0
          Enabled: false
          Invert Rainbow: false
          Max Color: 255; 255; 255
          Max Intensity: 1
          Min Color: 0; 0; 0
          Min Intensity: 0.30000037
          Name: real_map
          Position Transformer: XYZ
          Queue Size: 10
          Selectable: true
          Size (Pixels): 3
          Size (m): 0.100000001
          Style: Boxes
          Topic: /grid_map/occupancy
          Unreliable: false
          Use Fixed Frame: true
          Use rainbow: true
          Value: false
      Enabled: true
      Name: Mapping

    # Simulation：仿真机器人模型显示分组。
    - Class: rviz/Group
      Displays:

        # robot：无人机/机器人模型 Marker，来自 `/odom_visualization/robot`。
        - Class: rviz/Marker
          Enabled: true
          Marker Topic: /odom_visualization/robot
          Name: robot
          Namespaces:
            mesh: true
          Queue Size: 100
          Value: true
      Enabled: true
      Name: Simulation

    # depth：深度图显示，当前关闭。
    # 如果运行了 pcl_render_node 并发布 `/pcl_render_node/depth`，可以开启查看深度图。
    - Class: rviz/Image
      Enabled: false
      Image Topic: /pcl_render_node/depth
      Max Value: 1
      Median window: 5
      Min Value: 0
      Name: depth
      Normalize Range: true
      Queue Size: 2
      Transport Hint: raw
      Unreliable: false
      Value: false
  Enabled: true

  # Global Options：全局渲染和坐标系设置。
  # Fixed Frame=world 表示所有 Display 都会被转换到 world 坐标系下显示。
  Global Options:
    Background Color: 255; 253; 224
    Default Light: true
    Fixed Frame: world
    Frame Rate: 30
  Name: root

  # Tools：顶部工具栏中的交互工具。
  # 注意这里的 SetGoal 默认发 `/move_base_simple/goal`，EGO planner 是否使用它取决于 launch/节点订阅配置。
  Tools:
    - Class: rviz/Interact
      Hide Inactive Objects: true
    - Class: rviz/Select
    - Class: rviz/FocusCamera
    - Class: rviz/Measure
    - Class: rviz/SetInitialPose
      Topic: /initialpose
    - Class: rviz/SetGoal
      Topic: /move_base_simple/goal
    - Class: rviz_plugins/Goal3DTool
      Topic: /move_base_simple/goal
    - Class: rviz/PublishPoint
      Single click: true
      Topic: /clicked_point
  Value: true

  # Views：当前相机视角和保存的视角。
  # 只影响打开 RViz 后看到的观察角度，不影响规划/仿真。
  Views:
    Current:
      Class: rviz/ThirdPersonFollower
      Distance: 27.7380829
      Enable Stereo Rendering:
        Stereo Eye Separation: 0.0599999987
        Stereo Focal Distance: 1
        Swap Stereo Eyes: false
        Value: false
      Focal Point:
        X: -13.8514824
        Y: 1.02882814
        Z: 0.476891786
      Focal Shape Fixed Size: true
      Focal Shape Size: 0.0500000007
      Invert Z Axis: false
      Name: Current View
      Near Clip Distance: 0.00999999978
      Pitch: 0.839797616
      Target Frame: world
      Value: ThirdPersonFollower (rviz)
      Yaw: 3.14544106
    Saved:
      - Class: rviz/ThirdPersonFollower
        Distance: 17.4853859
        Enable Stereo Rendering:
          Stereo Eye Separation: 0.0599999987
          Stereo Focal Distance: 1
          Swap Stereo Eyes: false
          Value: false
        Focal Point:
          X: -16.3080025
          Y: 0.44920516
          Z: 8.5896736e-06
        Focal Shape Fixed Size: true
        Focal Shape Size: 0.0500000007
        Invert Z Axis: false
        Name: ThirdPersonFollower
        Near Clip Distance: 0.00999999978
        Pitch: 1.03479683
        Target Frame: <Fixed Frame>
        Value: ThirdPersonFollower (rviz)
        Yaw: 3.15040731

# Window Geometry：RViz 窗口大小、停靠面板折叠状态和 Qt 内部窗口布局。
# 这一大段通常不用手动改；它只影响界面布局，不影响显示 topic 或坐标系。
Window Geometry:
  Displays:
    collapsed: true
  Height: 1007
  Hide Left Dock: true
  Hide Right Dock: false
  QMainWindow State: 
  Selection:
    collapsed: false
  Time:
    collapsed: false
  Tool Properties:
    collapsed: false
  Views:
    collapsed: true
  Width: 1180
  X: 442
  Y: 123
  depth:
    collapsed: true
